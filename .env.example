# Resend — contact form emails and "email me my visit summary"
RESEND_API_KEY=re_xxxxxxxx
CONTACT_ADMIN_EMAIL=your-inbox@example.com
# Use a verified domain in Resend (RESEND_FROM is also supported).
# This sender is also used for the visit-summary emails sent to users.
RESEND_FROM_EMAIL=Aira <hello@yourdomain.org>