# Resend — contact form emails and "email me my visit summary"
RESEND_API_KEY=re_xxxxxxxx
CONTACT_ADMIN_EMAIL=your-inbox@example.com
# Use a verified domain in Resend (RESEND_FROM is also supported).
# This sender is also used for the visit-summary emails sent to users.
RESEND_FROM_EMAIL=Aira <hello@yourdomain.org>

# Postgres (optional — falls back to local SQLite if unset)
# Example: postgres://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME

# Custom pilot survey dashboard (not Django admin)
PILOT_DASHBOARD_USERNAME=pilot_admin
PILOT_DASHBOARD_PASSWORD=change-this-to-a-strong-password